# Copy to .env (gitignored). Real secrets — never commit.

# LLM providers — the UI lets users pick provider + model per request.
# Configure a key for each provider you want selectable (a provider with no
# key is shown disabled in the UI). ANTHROPIC_MODEL / OPENAI_MODEL are the
# per-provider defaults; LLM_PROVIDER is the default provider on load.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
LLM_PROVIDER=anthropic

# Geocat MCP server (eea-geonetwork)
GEOCAT_MCP_URL=https://sdi-mcp.dspx.eu/
# Optional bearer/token if the MCP server requires one for write tools
GEOCAT_MCP_AUTH=

# Firebase auth gate (dedicated project for this app)
FIREBASE_PROJECT_ID=your-project-id
# Optional extra restriction. Empty = trust Firebase (any authenticated user;
# manage access in the Firebase console). Set a comma-separated list to also
# enforce an allowlist in the backend.
ALLOWED_EMAILS=
ALLOWED_DOMAINS=

# Server
PORT=8080
