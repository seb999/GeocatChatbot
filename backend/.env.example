# Copy to .env (gitignored). Real secrets — never commit.

# Anthropic (Phase 2+)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Geocat MCP server (eea-geonetwork)
GEOCAT_MCP_URL=https://sdi-mcp.dspx.eu/
# Optional bearer/token if the MCP server requires one for write tools
GEOCAT_MCP_AUTH=

# Firebase auth gate (dedicated project for this app)
FIREBASE_PROJECT_ID=your-new-project-id
# Comma-separated. Deny-by-default: if both are empty, nobody can use the app.
ALLOWED_EMAILS=you@example.com
ALLOWED_DOMAINS=

# Server
PORT=8080
